# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Flask Backend Configuration
FLASK_SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=production

# MongoDB Configuration (if using local MongoDB)
# MONGODB_URI=mongodb://admin:admin123@mongodb:27017/test?authSource=admin
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=admin123
# MONGO_INITDB_DATABASE=test

# MongoDB Atlas Configuration (current setup)
# Your connection string is already in app_factory.py
# MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Frontend Configuration
VITE_API_BASE_URL=/api

# Firebase Configuration (already in source code)
# Make sure your firebase credentials JSON file is in flask-server/it-project-auth.json

# Port Configuration (optional - defaults shown)
# BACKEND_PORT=5000
# FRONTEND_PORT=80
# MONGODB_PORT=27017
